# Per-machine paths for our scripts. Copy to `.env.paths` (gitignored) on EACH machine, set real paths.
# LF_ROOT is auto-detected (this repo); you only set paths that live OUTSIDE the repo here.
# Keep TWO versions — one per machine; `git pull` never touches .env.paths, so they don't collide.
# (Named .env.paths, not .env.local, because .env.local is an upstream LlamaFactory tracked file.)

# ── machine A: /workspace1/zhijun ─────────────────────────────────────────────
export MODELS_DIR=/workspace1/zhijun/hf_download/models      # base models (Qwen3.5-2B, ...)
export LF_VENV=/workspace1/zhijun/LlamaFactory/.venv         # LlamaFactory python venv
export VLLM_VENV=/workspace1/zhijun/AgentRobot/.venv-vllm    # vLLM serving venv
export AGENTROBOT_ROOT=/workspace1/zhijun/AgentRobot         # AgentRobot repo (its own .venv for data prep)
export HF_HOME=/workspace1/zhijun/hf_download                # HF cache

# ── machine B: /highspeedstorage/Kokoro2 (edit + uncomment on that machine) ────
# export MODELS_DIR=/highspeedstorage/Kokoro2/hf_download/models
# export LF_VENV=/highspeedstorage/Kokoro2/LlamaFactory/.venv
# export VLLM_VENV=/highspeedstorage/Kokoro2/LlamaFactory/.venv-vllm
# export AGENTROBOT_ROOT=/highspeedstorage/Kokoro2/AgentRobot
# export HF_HOME=/highspeedstorage/Kokoro2/hf_download
